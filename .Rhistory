# Instale os pacotes se não os tiver
# install.packages(c("leaflet", "sf", "dplyr", "RColorBrewer"))
library(leaflet)
library(sf)
library(dplyr)
library(RColorBrewer)
# Criar dados fictícios de SPI para 3 pontos (ex: estações meteorológicas)
# SPI < -1.5 (Severo), > -1.5 (Moderado/Normal)
dados_spi <- data.frame(
id = c("Estação A", "Estação B", "Estação C"),
lat = c(-23.5, -20.0, -25.0),
lng = c(-46.6, -44.0, -50.0),
spi_valor = c(-1.8, -0.5, -2.1) # Ex: A e C com seca severa, B normal
)
# Converter data frame para objeto espacial (sf)
# Leaflet funciona melhor com coordenadas geográficas EPSG:4326 (WGS84)
map_sf <- st_as_sf(dados_spi, coords = c("lng", "lat"), crs = 4326)
#| echo: false
#| message: false
# Instale os pacotes se não os tiver
# install.packages(c("leaflet", "sf", "dplyr", "RColorBrewer"))
library(leaflet)
library(sf)
library(dplyr)
library(RColorBrewer)
# Criar dados fictícios de SPI para 3 pontos (ex: estações meteorológicas)
# SPI < -1.5 (Severo), > -1.5 (Moderado/Normal)
dados_spi <- data.frame(
id = c("Estação A", "Estação B", "Estação C"),
lat = c(-23.5, -20.0, -25.0),
lng = c(-46.6, -44.0, -50.0),
spi_valor = c(-1.8, -0.5, -2.1) # Ex: A e C com seca severa, B normal
)
# Converter data frame para objeto espacial (sf)
# Leaflet funciona melhor com coordenadas geográficas EPSG:4326 (WGS84)
map_sf <- st_as_sf(dados_spi, coords = c("lng", "lat"), crs = 4326)
# Criar paleta: Vermelho (Seca) -> Branco -> Azul (Úmido)
# Usando colorNumeric para dados contínuos
pal <- colorNumeric(
palette = "RdBu",
domain = c(-3, 3), # Escala típica de SPI
reverse = FALSE # RdBu: Vermelho é baixo(seco), Azul é alto(úmido)
)
leaflet(map_sf) %>%
addTiles() %>% # Adiciona o mapa base (OpenStreetMap)
addCircleMarkers(
color = ~pal(spi_valor),
radius = 10,
stroke = FALSE,
fillOpacity = 0.8,
popup = ~paste("Local:", id, "<br>", "SPI:", round(spi_valor, 2))
) %>%
addLegend(
pal = pal,
values = ~spi_valor,
title = "SPI",
position = "bottomright"
)
