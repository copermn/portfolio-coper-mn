# 1. Carregar bibliotecas necessárias
library(tidyverse) # Para manipulação de dados
library(sf)        # Para dados geográficos (se usar shapefile)
# 3. Pré-processamento
dados_fogo <- dados_fogo %>%
mutate(data = as.Date(date),
ano = format(data, "%Y"),
mes = format(data, "%m"))
file_path <- "D:/Fabio/3.eventos/2026/3.Encontro-com-jornalistas/dados_grafico_Carlos_23fev26/dados_evt_fogo/tb_event/eventos.xlsx"
dados<-read_excel(file_path, sheet = 1, col_names = TRUE)
# Definir a ordem correta dos meses (em português)
ordem_meses <- c("Jan", "Fev", "Mar", "Abr", "Mai", "Jun",
"Jul", "Ago", "Set", "Out", "Nov", "Dez")
# Transformar em fator ordenado
dados$mes <- factor(dados$mes, levels = ordem_meses)
dados$mes <- factor(dados$mes, levels = ordem_meses)
# Criar valores de mímos, média e máximo entre 2021–2025 (linhas)
linhas <- dados %>%
filter(ano >= 2021 & ano <= 2025) %>%
filter(sigla_uf == "AM") %>%
group_by(mes) %>%
summarise(
min  = min(id_evento, na.rm = TRUE),
mean = mean(id_evento, na.rm = TRUE),
max  = max(id_evento, na.rm = TRUE)
)
barras <- dados %>%
filter(ano == 2025) %>%
filter(sigla_uf == "AM")
# Construção do gráfico 1 (X, Y): valores em apenas 2 eixos
g1<- ggplot() +
# Barras 2025
geom_col(data = barras,
aes(x = mes, y = id_evento, fill = "2025"),
alpha = 0.8) +
# Linha máximo
geom_line(data = linhas,
aes(x = mes, y = max, color = "max", group = 1),
linewidth = 1) +
# Linha média
geom_line(data = linhas,
aes(x = mes, y = mean, color = "mean", group = 1),
linewidth = 1) +
# Linha mínimo
geom_line(data = linhas,
aes(x = mes, y = min, color = "min", group = 1),
linewidth = 1) +
# Escalas de cores
scale_fill_manual(values = c("2025" = "#B22222")) +
scale_color_manual(values = c(
"min"  = "#ffd7ab",
"mean" = "#cd966c",
"max"  = "#713112"
)) +
# Títulos
labs(
title = "Novos eventos de fogo por mês em AM",
x = "Meses",
y = "Nº de Eventos",
fill = "Ano",
color = "Métricas"
) +
theme_minimal(base_size = 13) +
theme(
plot.title = element_text(face = "bold"),
legend.position = "right"
)
g1
